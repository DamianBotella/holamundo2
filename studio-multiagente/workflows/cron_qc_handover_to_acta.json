    {
      "id": "qa-03",
      "name": "Load Architect Email",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -460,
        400
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT value FROM system_config WHERE key = 'architect_email'",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "cfxNZdzy0NB3xkYC",
          "name": "Postgres account"
        }
      }
    },
    {
      "id": "qa-04",
      "name": "Find Pending",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        -220,
        400
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT json_agg(t.* ORDER BY t.qc_completed_at DESC) AS rows, count(*) AS total\n  FROM (\n    SELECT qc.id AS qc_id, qc.project_id, qc.completed_at AS qc_completed_at,\n           p.name AS project_name, p.handover_date,\n           c.name AS client_name\n    FROM qc_checks qc\n    JOIN projects p ON p.id = qc.project_id\n    LEFT JOIN clients c ON c.id = p.client_id\n    WHERE qc.phase_key = 'recepcion_provisional'\n      AND qc.status = 'complete'\n      AND qc.completed_at > now() - INTERVAL '14 days'\n      AND NOT EXISTS (\n        SELECT 1 FROM contracts ct\n         WHERE ct.project_id = qc.project_id\n           AND ct.contract_type = 'acta_recepcion_provisional'\n           AND ct.status NOT IN ('cancelled','rejected')\n      )\n  ) t;",
        "options": {}
      },
      "credentials": {
        "postgres": {
          "id": "cfxNZdzy0NB3xkYC",
          "name": "Postgres account"
        }
      },
      "alwaysOutputData": true
    },
    {
      "id": "qa-05",
      "name": "Has Pending?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        20,
        400
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "h1",
              "leftValue": "={{ Number($json.total) || 0 }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "qa-06",
      "name": "Build Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        320
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst rows = (data.rows || []).map(r => '<tr>' +\n  '<td><b>' + (r.project_name || '?') + '</b></td>' +\n  '<td>' + (r.client_name || '?') + '</td>' +\n  '<td>' + (r.handover_date ? r.handover_date.substring(0,10) : '—') + '</td>' +\n  '<td>' + (r.qc_completed_at ? r.qc_completed_at.substring(0,10) : '—') + '</td>' +\n  '<td><code style=\\\"font-size:11px\\\">' + r.project_id + '</code></td>' +\n  '</tr>').join('');\nconst html = '<h2>Recepcion provisional cerrada — generar acta</h2>' +\n  '<p>Total: <b>' + data.total + '</b>. La checklist QC de recepcion provisional ha pasado a complete (LOE inicia). Genera el <code>acta_recepcion_provisional</code> firmable y registralo.</p>' +\n  '<table border=\\\"1\\\" cellpadding=\\\"6\\\" cellspacing=\\\"0\\\" style=\\\"border-collapse:collapse;font-family:sans-serif;font-size:13px\\\">' +\n  '<thead><tr style=\\\"background:#f3f4f6\\\"><th>Proyecto</th><th>Cliente</th><th>Handover</th><th>QC Completado</th><th>Project ID</th></tr></thead>' +\n  '<tbody>' + rows + '</tbody></table>' +\n  '<h3>Comando para generar el acta:</h3>' +\n  '<pre style=\\\"background:#f3f4f6;padding:10px;border-radius:6px;font-size:11px\\\">' +\n  'curl -X POST https://n8n-n8n.zzeluw.easypanel.host/webhook/contract-generate \\\\\\n' +\n  '  -H \"X-API-Key: arquitai-...\" -H \"Content-Type: application/json\" \\\\\\n' +\n  '  -d \\'{\"project_id\":\"&lt;uuid&gt;\",\"contract_type\":\"acta_recepcion_provisional\",\\\\\\n' +\n  '       \"parties\":[{\"role\":\"propiedad\",\"name\":\"...\"},{\"role\":\"contratista\",\"name\":\"...\"},{\"role\":\"director_ejecucion\",\"name\":\"Damian Martinez\"}],\\\\\\n' +\n  '       \"scope\":\"Sin incidencias / Incidencias anexas...\"}\\'' +\n  '</pre>' +\n  '<p style=\\\"font-size:11px;color:#7f8c8d\\\">Considera tambien generar el CFO con POST /webhook/certificate-generate type=cfo.</p>';\nreturn [{ json: { html_body: html, count: data.total } }];"
      }
    },
    {
      "id": "qa-07",
      "name": "Send Email",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
