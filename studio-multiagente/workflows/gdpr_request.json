    {
      "id": "gd-02",
      "name": "Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -460,
        300
      ],
      "parameters": {
        "jsCode": "const body = ($('Webhook').first().json.body) || {};\nconst valid = ['access','export','rectification','erasure','restriction','objection','portability'];\nif (!body.token) return [{ json: { valid:false, error:'token obligatorio (con purpose project_view o full_access)' } }];\nif (!body.request_type || !valid.includes(body.request_type)) return [{ json: { valid:false, error:'request_type debe ser ' + valid.join('|') } }];\nreturn [{ json: { valid:true, token: body.token, request_type: body.request_type, details: (body.details || '').toString().slice(0, 2000), client_email: body.client_email || null } }];"
      }
    },
    {
      "id": "gd-03",
      "name": "Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
