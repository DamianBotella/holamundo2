{
  "name": "agent_certificate_generator",
  "_n8n_id": "OqOHU6Uc6FkVWPEu",
  "_note": "Stub sincronizado 2026-04-26 (bloque 13). Para version completa: mcp__n8n__n8n_get_workflow id=OqOHU6Uc6FkVWPEu mode=full",
  "_purpose": "Genera certificados oficiales (CFO, habitabilidad, estructural, instalacion electrica/termica, idoneidad). POST /webhook/certificate-generate con {project_id, certificate_type, signer_name, collegiate_no, scope}; carga template de certificate_templates con placeholders {var}; sustituye con datos del proyecto+cliente; crea Google Doc; inserta fila en certificates; notifica a Damian para revisar y firmar.",
  "_triggers": "POST /webhook/certificate-generate",
  "_certificate_types": "cfo (Final de Obra LOE) | certificado_habitabilidad | certificado_estructural | certificado_instalacion_electrica (REBT) | certificado_instalacion_termica (RITE) | informe_idoneidad | otros",
  "_persists_to": "certificates (project_id, certificate_type, doc_id, drive_url, signer_name, collegiate_no, status='draft')",
  "nodes": [
    { "id": "cg-01", "name": "Webhook",              "type": "n8n-nodes-base.webhook",          "position": [-700, 300] },
    { "id": "cg-02", "name": "Validate",             "type": "n8n-nodes-base.code",             "position": [-460, 300] },
    { "id": "cg-03", "name": "Valid?",               "type": "n8n-nodes-base.if",               "position": [-220, 300] },
    { "id": "cg-04", "name": "Load Architect Email", "type": "n8n-nodes-base.postgres",         "position": [20, 220] },
    { "id": "cg-05", "name": "Load Project + Client","type": "n8n-nodes-base.postgres",         "position": [260, 220] },
    { "id": "cg-06", "name": "Load Template",        "type": "n8n-nodes-base.postgres",         "position": [500, 220] },
    { "id": "cg-07", "name": "Build Content",        "type": "n8n-nodes-base.code",             "position": [740, 220] },
    { "id": "cg-08", "name": "Create Google Doc",    "type": "n8n-nodes-base.googleDocs",       "position": [980, 220] },
    { "id": "cg-09", "name": "Insert Doc Body",      "type": "n8n-nodes-base.httpRequest",      "position": [1220, 220] },
    { "id": "cg-10", "name": "Insert Certificate Row","type": "n8n-nodes-base.postgres",        "position": [1460, 220] },
    { "id": "cg-11", "name": "Notify Damian",        "type": "n8n-nodes-base.gmail",            "position": [1700, 220] },
    { "id": "cg-12", "name": "Respond 201",          "type": "n8n-nodes-base.respondToWebhook", "position": [1940, 220] },
    { "id": "cg-13", "name": "Respond 400",          "type": "n8n-nodes-base.respondToWebhook", "position": [-220, 460] }
  ],
  "connections": {
    "Webhook":               { "main": [[{ "node": "Validate",              "type": "main", "index": 0 }]] },
    "Validate":              { "main": [[{ "node": "Valid?",                "type": "main", "index": 0 }]] },
    "Valid?":                {
      "main": [
        [{ "node": "Load Architect Email", "type": "main", "index": 0 }],
        [{ "node": "Respond 400",          "type": "main", "index": 0 }]
      ]
    },
    "Load Architect Email":  { "main": [[{ "node": "Load Project + Client", "type": "main", "index": 0 }]] },
    "Load Project + Client": { "main": [[{ "node": "Load Template",         "type": "main", "index": 0 }]] },
    "Load Template":         { "main": [[{ "node": "Build Content",         "type": "main", "index": 0 }]] },
    "Build Content":         { "main": [[{ "node": "Create Google Doc",     "type": "main", "index": 0 }]] },
    "Create Google Doc":     { "main": [[{ "node": "Insert Doc Body",       "type": "main", "index": 0 }]] },
    "Insert Doc Body":       { "main": [[{ "node": "Insert Certificate Row","type": "main", "index": 0 }]] },
    "Insert Certificate Row":{ "main": [[{ "node": "Notify Damian",         "type": "main", "index": 0 }]] },
    "Notify Damian":         { "main": [[{ "node": "Respond 201",           "type": "main", "index": 0 }]] }
  }
}
