{
  "name": "cron_contract_followup",
  "_n8n_id": "ZlzJpRwOnoG1altD",
  "_purpose": "Fase 2 de 3.13 (contracts). Cron diario 09:45 con 3 condiciones: (1) status IN (sent/ready_to_sign/partially_signed) y sent_at >7d (esperando firma), (2) status='draft' y created_at >14d (drafts olvidados), (3) status NOT IN (signed/cancelled/rejected/expired) y expires_at < now() (expirados). Si total > 0, email HTML agrupado al architect_email con secciones por categoria + curl helpers.",
  "_triggers": "cron 45 9 * * * (diario 09:45)",
  "_audited_by": "cron_workflow_audit (action='contract_followup_clean', INTERVAL 26h)",
  "nodes": [
    { "id": "ccf-01", "name": "Schedule 09:45 Daily", "type": "n8n-nodes-base.scheduleTrigger", "position": [-700, 300], "_cron": "45 9 * * *" },
    { "id": "ccf-02", "name": "Load Architect Email", "type": "n8n-nodes-base.postgres",        "position": [-460, 300] },
    { "id": "ccf-03", "name": "Find Issues",          "type": "n8n-nodes-base.postgres",        "position": [-220, 300], "_query_summary": "json_build_object con awaiting_signature/forgotten_drafts/expired arrays + total_issues" },
    { "id": "ccf-04", "name": "Has Issues?",          "type": "n8n-nodes-base.if",              "position": [20, 300], "_check": "total_issues > 0 (typeValidation: loose)" },
    { "id": "ccf-05", "name": "Build Email",          "type": "n8n-nodes-base.code",            "position": [260, 160] },
    { "id": "ccf-06", "name": "Send Email",           "type": "n8n-nodes-base.gmail",           "position": [500, 160] },
    { "id": "ccf-07", "name": "Log Issues Found",     "type": "n8n-nodes-base.postgres",        "position": [740, 160], "_action": "contract_followup_clean (status=warning, summary 'ran_with_issues')" },
    { "id": "ccf-08", "name": "Log Clean",            "type": "n8n-nodes-base.postgres",        "position": [260, 440], "_action": "contract_followup_clean (status=success)" }
  ],
  "connections": {
    "Schedule 09:45 Daily": { "main": [[{ "node": "Load Architect Email", "type": "main", "index": 0 }]] },
    "Load Architect Email": { "main": [[{ "node": "Find Issues",          "type": "main", "index": 0 }]] },
    "Find Issues":          { "main": [[{ "node": "Has Issues?",          "type": "main", "index": 0 }]] },
    "Has Issues?":          {
      "main": [
        [{ "node": "Build Email", "type": "main", "index": 0 }],
        [{ "node": "Log Clean",   "type": "main", "index": 0 }]
      ]
    },
    "Build Email":          { "main": [[{ "node": "Send Email",           "type": "main", "index": 0 }]] },
    "Send Email":           { "main": [[{ "node": "Log Issues Found",     "type": "main", "index": 0 }]] }
  }
}
