      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO activity_log (project_id, agent_name, action, status, input_summary)\nVALUES (NULL, 'cron_qc_handover_to_acta', 'suggest_acta_recepcion', 'success', $1)\nRETURNING id;",
        "options": {
          "queryReplacement": "={{ [ ('pending=' + $json.count) ] }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "cfxNZdzy0NB3xkYC",
          "name": "Postgres account"
        }
      }
    },
    {
