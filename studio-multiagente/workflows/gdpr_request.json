      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        20,
        60
      ],
      "parameters": {
        "jsCode": "const headers = $('Webhook').first().json.headers || {};\nconst body = $('Webhook').first().json.body || {};\nconst valid = $('Validate').first().json;\nreturn [{ json: {\n  source_ip: headers['x-real-ip'] || (headers['x-forwarded-for'] || '').split(',')[0].trim() || 'unknown',\n  endpoint: '/webhook/gdpr-request',\n  user_agent: headers['user-agent'] || '',\n  max_per_minute: 5,\n  max_per_hour: 20,\n  agent_name: 'gdpr_request',\n  payload_text: (valid.details || '') + ' ' + (valid.request_type || '') + ' ' + (body.token || '')\n}}];"
      }
    },
