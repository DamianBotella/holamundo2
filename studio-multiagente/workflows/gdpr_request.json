        140
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO gdpr_requests (client_id, project_id, token_id, request_type, client_email, client_ip, details, status)\nSELECT c.id, $1::uuid, $2::uuid, $3, $4, $5, $6, 'pending'\n  FROM projects p LEFT JOIN clients c ON c.id = p.client_id\n WHERE p.id = $1::uuid\nRETURNING id, client_id, request_type, status, created_at;",
        "options": {
          "queryReplacement": "={{ [ $('Validate Token').first().json.project_id, $('Validate Token').first().json.token_id, $('Validate').first().json.request_type, ($('Validate').first().json.client_email || ''), ($('Webhook').first().json.headers?.['x-real-ip'] || $('Webhook').first().json.headers?.['x-forwarded-for'] || 'unknown'), $('Validate').first().json.details ] }}"
        }
      },
