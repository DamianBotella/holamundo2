# Variables de entorno para n8n Workflow Builder
# ─────────────────────────────────────────────
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# NUNCA subas el archivo .env al repositorio (está en .gitignore)
# NUNCA compartas este archivo con credenciales reales
# ─────────────────────────────────────────────

# ─────────────────────────────────────────────
# INSTANCIA n8n
# ─────────────────────────────────────────────

# URL de tu instancia n8n (sin barra final)
# Ejemplos:
#   Cloud:       https://mi-usuario.app.n8n.cloud
#   Self-hosted: https://n8n.mi-dominio.com
#   Local:       http://localhost:5678
N8N_API_URL=https://tu-instancia.n8n.cloud

# API Key de tu instancia n8n
# Cómo obtenerla:
#   1. Abre tu instancia n8n
#   2. Ve a Settings > n8n API
#   3. Haz clic en "Create an API key"
#   4. Copia la key generada aquí
N8N_API_KEY=tu-n8n-api-key-aqui

# ─────────────────────────────────────────────
# SERVIDOR n8n-MCP
# ─────────────────────────────────────────────

# API Key del servidor n8n-MCP (para las herramientas de Claude)
# Cómo obtenerla:
#   1. Regístrate en https://dashboard.n8n-mcp.com
#   2. Plan gratuito: 100 llamadas/día (suficiente para desarrollo)
#   3. Copia tu API key desde el dashboard
MCP_API_KEY=tu-mcp-api-key-aqui

# ─────────────────────────────────────────────
# CONFIGURACIÓN OPCIONAL (solo si self-hosting)
# ─────────────────────────────────────────────

# Puerto de n8n (default: 5678)
# N8N_PORT=5678

# Modo de ejecución
# Opciones: main | queue | webhook
# N8N_EXECUTION_PROCESS=main

# Timezone para los triggers de Schedule
# Ejemplo: America/Mexico_City | Europe/Madrid | America/Buenos_Aires
# N8N_DEFAULT_BINARY_DATA_MODE=filesystem
