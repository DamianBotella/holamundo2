{
  "name": "cron_collab_review",
  "_n8n_id": "sJpNiWYCIlCvqB5i",
  "_purpose": "Cron diario 10:00 que vigila colaboradores externos: detecta 3 condiciones - (1) deadline vencido sin entrega/aprobacion, (2) status='delivered' sin approved >7d, (3) status='invited' sin respuesta >5d. Si hay >=1 envia email HTML al architect_email con tabla agrupada por categoria + dias retraso. Aplica leccion bloque 12: ambas ramas escriben action='collab_review_clean' (status warning|success) para que cron_workflow_audit lo vigile.",
  "_triggers": "cron 0 10 * * * (diario 10:00)",
  "_audited_by": "cron_workflow_audit (action='collab_review_clean', INTERVAL 26h)",
  "nodes": [
    { "id": "ccr-01", "name": "Schedule 10:00 Daily", "type": "n8n-nodes-base.scheduleTrigger", "position": [-700, 300], "_cron": "0 10 * * *" },
    { "id": "ccr-02", "name": "Load Architect Email", "type": "n8n-nodes-base.postgres",        "position": [-460, 300] },
    { "id": "ccr-03", "name": "Find Issues",          "type": "n8n-nodes-base.postgres",        "position": [-220, 300], "_query_summary": "json_build_object con overdue (deadline<CURRENT_DATE), stale_delivered (delivered_at<now()-7d), invited_no_response (invited_at<now()-5d), total_issues" },
    { "id": "ccr-04", "name": "Has Issues?",          "type": "n8n-nodes-base.if",              "position": [20, 300], "_check": "total_issues > 0 (typeValidation: loose)" },
    { "id": "ccr-05", "name": "Build Email",          "type": "n8n-nodes-base.code",            "position": [260, 160] },
    { "id": "ccr-06", "name": "Send Email",           "type": "n8n-nodes-base.gmail",           "position": [500, 160] },
    { "id": "ccr-07", "name": "Log Issues Found",     "type": "n8n-nodes-base.postgres",        "position": [740, 160], "_action": "collab_review_clean (status=warning con summary 'ran_with_issues: N pendientes')" },
    { "id": "ccr-08", "name": "Log Clean",            "type": "n8n-nodes-base.postgres",        "position": [260, 440], "_action": "collab_review_clean (status=success con summary '0 issues en colaboradores')" }
  ],
  "connections": {
    "Schedule 10:00 Daily": { "main": [[{ "node": "Load Architect Email", "type": "main", "index": 0 }]] },
    "Load Architect Email": { "main": [[{ "node": "Find Issues",          "type": "main", "index": 0 }]] },
    "Find Issues":          { "main": [[{ "node": "Has Issues?",          "type": "main", "index": 0 }]] },
    "Has Issues?":          {
      "main": [
        [{ "node": "Build Email", "type": "main", "index": 0 }],
        [{ "node": "Log Clean",   "type": "main", "index": 0 }]
      ]
    },
    "Build Email":          { "main": [[{ "node": "Send Email",           "type": "main", "index": 0 }]] },
    "Send Email":           { "main": [[{ "node": "Log Issues Found",     "type": "main", "index": 0 }]] }
  }
}
