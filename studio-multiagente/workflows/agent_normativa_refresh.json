{
  "name": "agent_normativa_refresh",
  "_n8n_id": "0Cyeaa85uLS7c8EE",
  "_note": "Stub sincronizado 2026-04-26 (bloque 14). Para version completa: mcp__n8n__n8n_get_workflow id=0Cyeaa85uLS7c8EE mode=full",
  "_purpose": "Cache warmer manual de normativa: webhook que recorre normativa_knowledge.sources y para cada uno fetcha contenido oficial via Jina Reader, lo procesa con LLM (extrae rules), calcula content_hash djb2 y lo compara con el anterior. Si hay cambios, marca regulatory_tasks de proyectos activos como requires_review. Email de resumen al final con sources changed + tasks marcados.",
  "_triggers": "POST /webhook/normativa-refresh (manual, X-API-Key)",
  "_loop_pattern": "SplitInBatches output[1] = procesar source -> Fetch -> LLM -> Parse Rules -> Compute Hash -> Read Previous Hash -> Attach Old Hash -> Delete Old Records -> Insert Knowledge Row (con content_hash) -> Aggregate Back -> SplitInBatches | output[0] = todos terminados -> Collect Changes -> Any Changes? -> Mark Tasks Requires Review -> Build Summary Email -> Send Summary Email",
  "_change_detection": "djb2 hash sobre el content de cada normativa_knowledge row. Si hash != prev_hash y prev_hash IS NOT NULL -> changed. Marca regulatory_tasks WHERE status IN ('detected','confirmed') AND project_id en proyectos activos.",
  "_persists_to": "normativa_knowledge (con content_hash), regulatory_tasks.status (cambia a requires_review en cascada)",
